# Copy this file to `.env` and fill in your API key.
# `.env` is gitignored — never commit it.

# -----------------------------------------------------------------------------
# Default model the curriculum points at (LiteLLM model-string format).
# To swap providers, change this line AND fill the matching key below.
# See https://docs.litellm.ai/docs/providers
# -----------------------------------------------------------------------------
LITELLM_MODEL=claude-haiku-4-5-20251001

# -----------------------------------------------------------------------------
# Provider API keys — fill the key for the provider you chose above.
# You only need ONE of these for the curriculum to work.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your_key_here
# OPENAI_API_KEY=sk-proj-your_key_here
# GEMINI_API_KEY=your_key_here

# -----------------------------------------------------------------------------
# General config
# -----------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
